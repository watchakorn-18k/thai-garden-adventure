FROM node:22-bookworm-slim

WORKDIR /app

ENV WRANGLER_SEND_METRICS=false

COPY package.json ./
RUN npm install

COPY src ./src
COPY worker ./worker

EXPOSE 8787

CMD ["node", "node_modules/wrangler/bin/wrangler.js", "dev", "--config", "worker/match/wrangler.toml", "--ip", "0.0.0.0", "--port", "8787", "--local-protocol", "http"]
